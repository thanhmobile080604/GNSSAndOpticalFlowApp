<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:background="@color/black_60">

    <androidx.constraintlayout.utils.widget.ImageFilterView
        android:id="@+id/bg_parent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@color/white"
        app:round="40dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/tvVelocity"
        android:layout_marginBottom="-32dp"
        android:layout_marginTop="-6dp"
        app:layout_constraintTop_toTopOf="@id/ivThumb"
        app:layout_constraintWidth_percent="0.84" />

    <ImageView
        android:id="@+id/ivThumb"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_information"
        app:layout_constraintDimensionRatio="1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.36"
        app:layout_constraintWidth_percent="0.2" />

    <TextView
        android:id="@+id/tvLatitude"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/inter_semi_bold"
        android:text="Vĩ độ: "
        android:textColor="@color/black"
        android:textSize="20sp"
        android:layout_marginStart="32dp"
        app:layout_constraintStart_toStartOf="@id/bg_parent"
        app:layout_constraintTop_toBottomOf="@id/ivThumb" />

    <TextView
        android:id="@+id/tvLongitude"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:fontFamily="@font/inter_semi_bold"
        android:text="Kinh độ: "
        android:textColor="@color/black"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="@id/tvLatitude"
        app:layout_constraintTop_toBottomOf="@id/tvLatitude" />

    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:fontFamily="@font/inter_semi_bold"
        android:text="Thời gian: "
        android:textColor="@color/black"
        android:layout_marginEnd="4dp"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="@id/bg_parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="@id/tvLongitude"
        app:layout_constraintTop_toBottomOf="@id/tvLongitude" />

    <TextView
        android:id="@+id/tvVelocity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:fontFamily="@font/inter_semi_bold"
        android:text="Vận tốc: "
        android:textColor="@color/black"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="@id/tvTime"
        app:layout_constraintTop_toBottomOf="@id/tvTime" />

    <ImageView
        android:id="@+id/ivCLose"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_close"
        app:layout_constraintTop_toTopOf="@id/bg_parent"
        app:layout_constraintEnd_toEndOf="@id/bg_parent"
        android:layout_margin="22dp"/>



</androidx.constraintlayout.widget.ConstraintLayout>

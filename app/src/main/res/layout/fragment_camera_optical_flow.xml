<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main">

    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="40dp"
        android:scaleX="-1"
        android:src="@drawable/ic_arrow_right"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cvCamera"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardUseCompatPadding="false"
        app:layout_constraintDimensionRatio="398:430"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.48"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivBack">

        <org.opencv.android.JavaCameraView
            android:id="@+id/camera_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </androidx.cardview.widget.CardView>

    <androidx.constraintlayout.utils.widget.ImageFilterView
        android:id="@+id/motion_vector"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintDimensionRatio="1"
        app:layout_constraintStart_toStartOf="@id/cvCamera"
        app:layout_constraintTop_toBottomOf="@+id/cvCamera"
        app:layout_constraintWidth_percent="0.28"
        app:round="24dp"
        app:srcCompat="@drawable/ic_launcher_foreground" />

    <TextView
        android:id="@+id/resetMV"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="6dp"
        android:background="@drawable/bg_blue_gradient_40_left"
        android:fontFamily="@font/inter_bold"
        android:gravity="center"
        android:text="Reset"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@id/update_features_button"
        app:layout_constraintDimensionRatio="86:56"
        app:layout_constraintStart_toEndOf="@id/update_features_button"
        app:layout_constraintTop_toTopOf="@+id/update_features_button"
        app:layout_constraintWidth_percent="0.2" />

    <TextView
        android:id="@+id/update_features_button"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_blue_gradient_40_left"
        android:fontFamily="@font/inter_bold"
        android:gravity="center"
        android:text="Update"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:layout_constraintDimensionRatio="86:56"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/motion_vector"
        app:layout_constraintWidth_percent="0.2" />

    <TextView
        android:id="@+id/vel_pred"
        android:layout_width="94dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="Velocity"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="@id/motion_vector"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/motion_vector"
        app:layout_constraintTop_toBottomOf="@+id/cvCamera" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter_regular"
        android:text="Mode"
        android:textColor="@color/white"
        app:layout_constraintBottom_toTopOf="@id/ofType"
        app:layout_constraintEnd_toEndOf="@id/ofType"
        app:layout_constraintStart_toStartOf="@id/ofType" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/ofType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:splitTrack="false"
        app:layout_constraintBottom_toBottomOf="@id/update_features_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/resetMV"
        app:switchMinWidth="48dp"
        app:thumbTint="@android:color/white"
        app:trackTint="@color/switch_track_selector" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2dp"
        android:fontFamily="@font/inter_regular"
        android:text="Sensitivity"
        android:textColor="@color/white"
        app:layout_constraintBottom_toTopOf="@id/sensitivity_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/resetMV" />

    <SeekBar
        android:id="@+id/sensitivity_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:max="100"
        android:maxHeight="6dp"
        android:minHeight="6dp"
        android:progress="50"
        android:progressDrawable="@drawable/seekbar_opacity"
        android:thumb="@drawable/ripple_purple_gradient_thumb"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/resetMV"
        app:layout_constraintTop_toBottomOf="@+id/update_features_button"
        app:layout_constraintVertical_bias="0.6"
        app:layout_constraintWidth_percent="0.4" />

    <ImageView
        android:id="@+id/ivVideRecord"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:src="@drawable/ic_start_record_purple"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/resetMV"
        app:layout_constraintStart_toStartOf="@id/update_features_button"
        app:layout_constraintTop_toBottomOf="@id/update_features_button" />


</androidx.constraintlayout.widget.ConstraintLayout>
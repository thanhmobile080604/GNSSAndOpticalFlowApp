<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:background="@color/black_60">

    <androidx.constraintlayout.utils.widget.ImageFilterView
        android:id="@+id/bg_parent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@color/white"
        app:round="40dp"
        app:layout_constraintTop_toTopOf="@id/ivThumb"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/infoContainer"
        android:layout_marginTop="-6dp"
        android:layout_marginBottom="-32dp"
        app:layout_constraintWidth_percent="0.84" />

    <ImageView
        android:id="@+id/ivThumb"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/ic_information"
        android:scaleType="fitCenter"
        app:layout_constraintDimensionRatio="1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.18"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.2" />

    <ImageView
        android:id="@+id/ivCLose"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_margin="22dp"
        android:src="@drawable/ic_close"
        app:layout_constraintTop_toTopOf="@id/bg_parent"
        app:layout_constraintEnd_toEndOf="@id/bg_parent" />

    <LinearLayout
        android:id="@+id/infoContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="32dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/ivThumb"
        app:layout_constraintStart_toStartOf="@id/bg_parent"
        app:layout_constraintEnd_toEndOf="@id/bg_parent">

        <TextView
            android:id="@+id/tvTotalSats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tổng số vệ tinh: "
            android:textColor="@color/black"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semi_bold" />

        <TextView
            android:id="@+id/tvSvid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="SVID: "
            android:textColor="@color/black"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semi_bold" />

        <TextView
            android:id="@+id/tvConstellation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Chòm sao: "
            android:textColor="@color/black"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semi_bold" />

        <TextView
            android:id="@+id/tvSignalStrength"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Cường độ tín hiệu (Cn0DbHz): "
            android:textColor="@color/black"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semi_bold" />

        <TextView
            android:id="@+id/tvElevation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Góc ngẩng: "
            android:textColor="@color/black"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semi_bold" />

        <TextView
            android:id="@+id/tvAzimuth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Phương vị: "
            android:textColor="@color/black"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semi_bold" />

        <TextView
            android:id="@+id/tvCarrierFrequency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Tần số sóng mang: "
            android:textColor="@color/black"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semi_bold" />

        <TextView
            android:id="@+id/tvUsedInFix"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Trạng thái sử dụng: "
            android:textColor="@color/black"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semi_bold" />

        <TextView
            android:id="@+id/tvSource"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Nguồn: "
            android:textColor="@color/black"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semi_bold" />

        <TextView
            android:id="@+id/tvLatitude"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Vĩ độ: "
            android:textColor="@color/black"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semi_bold" />

        <TextView
            android:id="@+id/tvLongitude"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Kinh độ: "
            android:textColor="@color/black"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semi_bold" />

        <TextView
            android:id="@+id/tvAltitude"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Độ cao: "
            android:textColor="@color/black"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semi_bold" />

        <TextView
            android:id="@+id/tvVelocity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Tốc độ: "
            android:textColor="@color/black"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semi_bold" />

        <TextView
            android:id="@+id/tvEphemeris"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Lịch thiên văn: "
            android:textColor="@color/black"
            android:textSize="14sp"
            android:fontFamily="@font/inter_semi_bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
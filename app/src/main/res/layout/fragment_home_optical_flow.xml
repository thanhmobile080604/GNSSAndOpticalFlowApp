<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main">

    <TextView
        android:id="@+id/imgTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="60dp"
        android:fontFamily="@font/inter_extra_bold"
        android:gravity="center"
        android:text="Optical Flow"
        android:textColor="@color/white"
        android:textSize="40sp"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btnFunc1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="28dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:focusable="true"
        android:clickable="true"
        android:src="@drawable/bg_black_purple_gradient"
        app:layout_constraintDimensionRatio="760:248"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgTitle" />

    <ImageView
        android:id="@+id/ivCamera"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="20dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_camera"
        app:layout_constraintBottom_toBottomOf="@id/btnFunc1"
        app:layout_constraintDimensionRatio="1"
        app:layout_constraintStart_toStartOf="@id/btnFunc1"
        app:layout_constraintTop_toTopOf="@id/btnFunc1" />

    <TextView
        android:id="@+id/tvUseCamera"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:text="Use Camera"
        android:fontFamily="@font/inter_bold"
        android:textColor="@color/white"
        android:textSize="20sp"
        app:layout_constraintStart_toEndOf="@id/ivCamera"
        app:layout_constraintBottom_toBottomOf="@id/btnFunc1"
        app:layout_constraintEnd_toEndOf="@id/btnFunc1"
        app:layout_constraintTop_toTopOf="@id/btnFunc1" />

    <ImageView
        android:id="@+id/btnFunc2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:focusable="true"
        android:clickable="true"
        android:src="@drawable/bg_black_purple_gradient"
        app:layout_constraintDimensionRatio="760:248"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnFunc1" />

    <ImageView
        android:id="@+id/ivUpload"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="20dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_upload"
        app:layout_constraintBottom_toBottomOf="@id/btnFunc2"
        app:layout_constraintDimensionRatio="1"
        app:layout_constraintEnd_toEndOf="@id/btnFunc2"
        app:layout_constraintTop_toTopOf="@id/btnFunc2" />

    <TextView
        android:id="@+id/tvUpload"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:text="Upload Video"
        android:fontFamily="@font/inter_bold"
        android:textColor="@color/white"
        android:textSize="20sp"
        app:layout_constraintEnd_toStartOf="@id/ivUpload"
        app:layout_constraintBottom_toBottomOf="@id/btnFunc2"
        app:layout_constraintStart_toStartOf="@id/btnFunc2"
        app:layout_constraintTop_toTopOf="@id/btnFunc2" />

    <ImageView
        android:id="@+id/btnFunc3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:focusable="true"
        android:clickable="true"
        android:src="@drawable/bg_black_purple_gradient"
        app:layout_constraintDimensionRatio="760:248"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnFunc2" />

    <ImageView
        android:id="@+id/ivStorage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="6dp"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_storage"
        app:layout_constraintBottom_toBottomOf="@id/btnFunc3"
        app:layout_constraintDimensionRatio="1"
        app:layout_constraintStart_toStartOf="@id/btnFunc3"
        app:layout_constraintTop_toTopOf="@id/btnFunc3" />

    <TextView
        android:id="@+id/tvStorage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:text="Storage"
        android:fontFamily="@font/inter_bold"
        android:textColor="@color/white"
        android:textSize="20sp"
        app:layout_constraintStart_toEndOf="@id/ivStorage"
        app:layout_constraintBottom_toBottomOf="@id/btnFunc3"
        app:layout_constraintEnd_toEndOf="@id/btnFunc3"
        app:layout_constraintTop_toTopOf="@id/btnFunc3" />

</androidx.constraintlayout.widget.ConstraintLayout>
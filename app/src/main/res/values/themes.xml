<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.BaseProject" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- TODO PRIMARY COLOR -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- TODO SECONDARY COLOR -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- TODO STATUS BAR COLOR -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- TODO EXTENSIONS -->
        <!-- Color of ?attr/selectableBackground -->
        <item name="android:colorControlHighlight">@color/ripple_color_main</item>
    </style>

    <style name="Theme.BaseProject" parent="Base.Theme.BaseProject" />

    <style name="AlertDialog" parent="@android:style/Theme.Translucent.NoTitleBar">
        <item name="android:windowEnterAnimation">@anim/fade_in</item>
        <item name="android:windowExitAnimation">@anim/fade_out</item>
    </style>

    <style name="LoadingDialog" parent="AlertDialog">
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <style name="FadeTransition">
        <item name="android:windowEnterAnimation">@anim/popup_show</item>
        <item name="android:windowExitAnimation">@anim/popup_hide</item>
    </style>

    <style name="DialogFullScreen">
        <item name="android:windowMinWidthMajor">100%</item>
        <item name="android:windowMinWidthMinor">100%</item>
    </style>

    <style name="DialogModal" parent="Theme.AppCompat.DayNight.Dialog">
        <item name="android:windowMinWidthMajor">65%</item>
        <item name="android:windowMinWidthMinor">85%</item>
    </style>

    <style name="CustomBottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.7</item>
    </style>

    <style name="CustomBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>
</resources>